{
    "name": "Drugref 2026 Dev",
    "dockerComposeFile": ["docker-compose.yml"],
    "service": "drugref",
    "workspaceFolder": "/workspace",
    "shutdownAction": "stopCompose",
    "dockerComposeOptions": ["--project-name", "drugref2026"],
    "postCreateCommand": "cd /workspace && mvn -B dependency:go-offline dependency:sources dependency:resolve -Dclassifier=javadoc && make install",

    "customizations": {
        "vscode": {
            "extensions": [
                "waderyan.gitblame",
                "vscjava.vscode-java-pack",
                "redhat.fabric8-analytics",
                "anthropic.claude-code"
            ],
            "settings": {
                "terminal.integrated.shell.linux": "/bin/bash",
                "java.compile.nullAnalysis.mode": "automatic",
                "java.configuration.updateBuildConfiguration": "interactive",
                "java.jdt.ls.vmargs": "-XX:+UseParallelGC -XX:GCTimeRatio=4 -XX:AdaptiveSizePolicyWeight=90 -Dsun.zip.disableMemoryMapping=true -Xmx4G -Xms512m -Xlog:disable",
                "java.maven.downloadSources": false
            }
        }
    },

    "forwardPorts": [8080, 8000, 3306],
    "containerUser": "root",
    "remoteUser": "root"
}
